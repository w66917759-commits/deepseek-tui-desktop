{
  "name": "deepseek-tui-desktop",
  "version": "0.1.9",
  "private": true,
  "description": "Desktop shell for DeepSeek TUI coding agent.",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "concurrently -k \"vite --host 127.0.0.1\" \"wait-on http://127.0.0.1:5173 && electron .\"",
    "test": "node --test",
    "typecheck": "tsc --noEmit",
    "build": "vite build",
    "runtime:sync-local": "node scripts/sync-local-runtime.cjs",
    "prepare:win-runtime": "node scripts/prepare-win-runtime.cjs",
    "dist:mac": "npm run build && electron-builder --mac dmg --arm64",
    "dist:mac:official": "node scripts/release-mac-official.cjs",
    "dist:win": "npm run prepare:win-runtime && npm run build && electron-builder --win nsis --x64 -c.npmRebuild=false"
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/xterm": "^5.5.0",
    "deepseek-tui": "0.8.36",
    "lucide-react": "^0.468.0",
    "node-pty": "^1.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.17",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "typescript": "^5.7.2",
    "vite": "^6.0.5",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.deepseek.tui.desktop",
    "productName": "DeepSeek TUI Desktop",
    "copyright": "Copyright © 2026 DeepSeek TUI Desktop",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**",
      "electron/**",
      "node_modules/**",
      "package.json",
      "!**/.env",
      "!**/.env.*",
      "!**/secrets.json",
      "!**/settings.json",
      "!**/remote-auth.json",
      "!**/automations.json",
      "!**/history.json",
      "!**/mcp.custom.json",
      "!**/mcp.runtime.json",
      "!**/mcp.presets.json",
      "!**/deepseek.desktop.managed.toml",
      "!**/.deepseek/**"
    ],
    "asarUnpack": [
      "electron/skills/**",
      "node_modules/deepseek-tui/bin/downloads/**",
      "node_modules/node-pty/**"
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "hardenedRuntime": true,
      "icon": "build/icon.icns",
      "sign": "build/debug-sign-mac.cjs",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        }
      ]
    },
    "dmg": {
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.ico",
      "requestedExecutionLevel": "asInvoker",
      "verifyUpdateCodeSignature": false,
      "signtoolOptions": {
        "publisherName": "DeepSeek TUI Desktop Local Test",
        "signingHashAlgorithms": [
          "sha256"
        ]
      }
    },
    "nsis": {
      "artifactName": "${productName}-${version}-win-${arch}-setup.${ext}",
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "${productName}",
      "deleteAppDataOnUninstall": false
    }
  }
}
